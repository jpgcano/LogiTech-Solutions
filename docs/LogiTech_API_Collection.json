              "mode": "raw",
              "raw": "{\n  \"customer_email\": \"juan.perez@example.com\",\n  \"products\": [\n    {\"sku\": \"PROD-001\", \"quantity\": 2},\n    {\"sku\": \"PROD-002\", \"quantity\": 1}\n  ]\n}"
