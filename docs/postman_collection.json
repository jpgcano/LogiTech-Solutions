{
  "info": {
    "name": "LogiTech Solutions API",
    "description": "REST API for MegaStore Global data migration and management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Migration",
      "item": [
        {
          "name": "Run Migration",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/migrate",
              "host": ["{{base_url}}"],
              "path": ["api", "migrate"]
            },
            "description": "Ejecuta la migración de datos desde CSV (limpia e inserta de nuevo)"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/Products"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"NEW-PROD-001\",\n  \"name\": \"Producto de Prueba\",\n  \"categoryId\": 6,\n  \"unitPrice\": 100.0\n}"
            },
            "url": "{{base_url}}/api/Products"
          }
        }
      ]
    },
    {
      "name": "Suppliers",
      "item": [
        {
          "name": "Get All Suppliers",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/Suppliers"
          }
        },
        {
          "name": "Create Supplier",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplier_email\": \"proveedor@ejemplo.com\",\n  \"supplier_name\": \"Nuevo Proveedor Inc\"\n}"
            },
            "url": "{{base_url}}/api/Suppliers"
          }
        }
      ]
    },
    {
      "name": "Business Intelligence",
      "item": [
        {
          "name": "Suppliers Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/bi/suppliers-summary",
            "description": "Resumen de proveedores con valor total de inventario"
          }
        },
        {
          "name": "Customer Purchase History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/bi/customer-history/andres.lopez@gmail.com",
            "description": "Historial completo de compras de un cliente vía MongoDB"
          }
        },
        {
          "name": "Top Products by Category",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/bi/top-products-by-category/Electronics",
            "description": "Productos más vendidos en una categoría ordenados por ingresos"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ]
}