  },
  "item": [
    {
      "name": "Migration",
      "item": [
        {
          "name": "Run Migration",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/migrate",
              "host": ["{{base_url}}"],
              "path": ["api", "migrate"]
            },
            "description": "Execute data migration from CSV (clears and re-inserts)"
          },
          "response": []
        }
      ]
    },
